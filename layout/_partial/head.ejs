<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" name="viewport" />
    <meta name="description" content="<%= page.title %>" />
    <meta name="hexo-theme-A4" content="<%= theme.version %>" />
    <%
    // 获取CDN开关配置
    var cdnEnabled = is_cdn_enabled();
    %>
    <% if (cdnEnabled) { %>
        <link rel="alternate icon" type="image/webp" href="<%- cdn_theme_url(theme.favicon) %>">
    <% } else { %>
        <link rel="alternate icon" type="image/webp" href="<%- url_for(theme.favicon) %>">
    <% } %>
    <title>
      <% 
        let pageTitle = '';
        if (theme.displayTitleInTab) {
            // 1. 优先用页面自带的 title（文章/自定义页面）
            if (page.title) {
                pageTitle = page.title;
            } 
            // 2. 处理分类详情页（从URL解析，不管主题变量）
            else if (page.path && page.path.indexOf('categories/') === 0) {
                // 解析 URL 里的分类名
                let urlParts = page.path.split('/');
                // 取出 categories/ 后面的部分，解码中文
                if (urlParts.length >= 2 && urlParts[1]) {
                    //pageTitle = decodeURIComponent(urlParts[1]);
                    // 可选：加上前缀，比如「分类：软件」
                    pageTitle = '分类·' + decodeURIComponent(urlParts[1]);
                }
            }
            // 3. 处理标签详情页
            else if (page.path && page.path.indexOf('tags/') === 0) {
                let urlParts = page.path.split('/');
                if (urlParts.length >= 2 && urlParts[1]) {
                    //pageTitle = decodeURIComponent(urlParts[1]);
                    pageTitle = '标签·' + decodeURIComponent(urlParts[1]);
                }
            }
        }
      %>
      <%= (pageTitle ? pageTitle + ' | ' : '') + config.title + (config.subtitle ? ' | ' + config.subtitle : '') %>
    </title>

    <%
    // 从配置中获取CSS文件列表
    var baseCssFiles = get_list_from_config(theme.resources.theme.head_css);

    // 条件可选CSS文件映射
    var optionalCssFiles = {
        lightgallery: {
            check: config.lightgallery.enable,
            path: theme.resources.theme.optional_css.lightgallery
        },
        waline: {
            check: theme.enable_pjax ?
                theme.comment.enable && (!theme.no_internet_local_deploy || (theme.no_internet_local_deploy && theme.no_internet_local_deploy_enable_comment)) && (theme.comment.use === 'waline') :
                (is_post() || is_page()) && theme.comment.enable && (!theme.no_internet_local_deploy || (theme.no_internet_local_deploy && theme.no_internet_local_deploy_enable_comment)) && 
                (!page.hasOwnProperty('comment') || (page.hasOwnProperty('comment') && page.comment)) && (theme.comment.use === 'waline'),
            path: theme.resources.theme.optional_css.waline
        },
        returnToTop: {
            check: theme.tool.returnToTop,
            paths: get_list_from_config(theme.resources.theme.optional_css.returnToTop)
        },
        leftToc: {
            check: theme.enable_pjax ? theme.tool.leftToc :
                is_post() && (!('leftToc' in page) || page.leftToc == true) && theme.tool.leftToc,
            path: theme.resources.theme.optional_css.leftToc
        },
        returnToLast: {
            check: theme.tool.returnToLast,
            path: theme.resources.theme.optional_css.returnToLast
        }
    };
    %>

    <%# 加载基础CSS文件 %>
    <% baseCssFiles.forEach(function(file) { %>
        <% if (cdnEnabled) { %>
            <%- css(cdn_theme_url(file)) %>
        <% } else { %>
            <%- css(file) %>
        <% } %>
    <% }); %>

    <%# 加载条件可选CSS文件 %>
    <% Object.keys(optionalCssFiles).forEach(function(key) { %>
        <% var item = optionalCssFiles[key]; %>
        <% if (item.check) { %>
            <% if (item.paths) { %>
                <% item.paths.forEach(function(path) { %>
                    <% if (cdnEnabled) { %>
                        <%- css(cdn_theme_url(path)) %>
                    <% } else { %>
                        <%- css(path) %>
                    <% } %>
                <% }); %>
            <% } else if (item.path) { %>
                <% if (cdnEnabled) { %>
                    <%- css(cdn_theme_url(item.path)) %>
                <% } else { %>
                    <%- css(item.path) %>
                <% } %>
            <% } %>
        <% } %>
    <% }); %>

    <%# 加载自定义CSS %>
    <% if(theme.inject.css) { %>
        <%- css(theme.inject.css) %>
    <% } %>

    <% if(theme.baseElement.href || theme.baseElement.target) { %>
        <base
            <% if(theme.baseElement.href) { %>
                href="<%- theme.baseElement.href %>"
            <% } %>
            <% if(theme.baseElement.target) { %>
                target="<%- theme.baseElement.target %>"
            <% } %>
        >
    <% } %>

    <!-- <link rel="stylesheet" href="https://chinese-fonts-cdn.deno.dev/packages/lxgwwenkai/dist/LXGWWenKai-Regular/result.css" /> -->
