<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" name="viewport" />
    <meta name="description" content="<%= page.title %>" />
    <meta name="hexo-theme-A4" content="<%= theme.version %>" />
    <%
    // 获取CDN开关配置
    var cdnEnabled = is_cdn_enabled();
    %>
    <% if (cdnEnabled) { %>
        <link rel="alternate icon" type="image/webp" href="<%- cdn_theme_url(theme.favicon) %>">
    <% } else { %>
        <link rel="alternate icon" type="image/webp" href="<%- url_for(theme.favicon) %>">
    <% } %>
    <title><%= (theme.displayTitleInTab && page.title ? page.title + ' | ' : '') + config.title + (config.subtitle ? ' | ' + config.subtitle : '') %></title>

    <%
    // 从配置中获取CSS文件列表
    var baseCssFiles = get_list_from_config(theme.resources.theme.head_css);

    // 条件可选CSS文件映射
    var optionalCssFiles = {
        lightgallery: {
            check: config.lightgallery.enable,
            path: theme.resources.theme.optional_css.lightgallery
        },
        waline: {
            check: (is_post() || is_page()) && theme.comment.enable && (!page.hasOwnProperty('comment') || (page.hasOwnProperty('comment') && page.comment)),
            path: theme.resources.theme.optional_css.waline
        },
        returnToTop: {
            check: theme.tool.returnToTop,
            paths: get_list_from_config(theme.resources.theme.optional_css.returnToTop)
        },
        leftToc: {
            check: is_post() && (!('leftToc' in page) || page.leftToc == true) && theme.tool.leftToc,
            path: theme.resources.theme.optional_css.leftToc
        },
        returnToLast: {
            check: theme.tool.returnToLast,
            path: theme.resources.theme.optional_css.returnToLast
        }
    };
    %>

    <%# 加载基础CSS文件 %>
    <% baseCssFiles.forEach(function(file) { %>
        <% if (cdnEnabled) { %>
            <%- css(cdn_theme_url(file)) %>
        <% } else { %>
            <%- css(file) %>
        <% } %>
    <% }); %>

    <%# 加载条件可选CSS文件 %>
    <% Object.keys(optionalCssFiles).forEach(function(key) { %>
        <% var item = optionalCssFiles[key]; %>
        <% if (item.check) { %>
            <% if (item.paths) { %>
                <% item.paths.forEach(function(path) { %>
                    <% if (cdnEnabled) { %>
                        <%- css(cdn_theme_url(path)) %>
                    <% } else { %>
                        <%- css(path) %>
                    <% } %>
                <% }); %>
            <% } else if (item.path) { %>
                <% if (cdnEnabled) { %>
                    <%- css(cdn_theme_url(item.path)) %>
                <% } else { %>
                    <%- css(item.path) %>
                <% } %>
            <% } %>
        <% } %>
    <% }); %>

    <%# 加载自定义CSS %>
    <% if(theme.inject.css) { %>
        <%- css(theme.inject.css) %>
    <% } %>

    <% if(theme.baseElement.href || theme.baseElement.target) { %>
        <base
            <% if(theme.baseElement.href) { %>
                href="<%- theme.baseElement.href %>"
            <% } %>
            <% if(theme.baseElement.target) { %>
                target="<%- theme.baseElement.target %>"
            <% } %>
        >
    <% } %>

    <!-- <link rel="stylesheet" href="https://chinese-fonts-cdn.deno.dev/packages/lxgwwenkai/dist/LXGWWenKai-Regular/result.css" /> -->
    <link rel='stylesheet' href='<%- cdn_lib_url("lxgwwenkai") %>' />
</head>
