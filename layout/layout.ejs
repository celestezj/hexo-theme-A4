<!DOCTYPE html>
<%
// 获取CDN开关配置
var cdnEnabled = is_cdn_enabled();
%>
<%# 挂载到locals，全模板共享，单请求生命周期唯一 %>
<% if (!locals.loadedLibs) locals.loadedLibs = []; %>
<html lang="<%= config.language || 'en' %>">
    <%- partial('_partial/configcss/font') %>
    <%- partial('_partial/head') %>
    <%- partial('_partial/configcss/width') %>
    <%- partial('_partial/configcss/color') %>
    <%- partial('_partial/configcss/imageShow') %>

    <body>
        <% if(theme.tool.darkMode) { %>
        <% if (!locals.loadedLibs.includes("darkreader")) { %>
            <script src='<%- cdn_lib_url("darkreader") %>'></script><!--这个js会有跨域问题（不会造成功能问题，就是浏览器控制台会报错而已）-->
            <% locals.loadedLibs.push("darkreader"); %>
        <% } %>
        <!--script>
            // 拦截 DarkReader 所有报错（PS：不需要这段代码了，豆包给了一个跨域修复的方案，就加一行代码：DarkReader.setFetchMethod(window.fetch);）
            const originalError = console.error;
            console.error = function(...args) {
            try {
                // 只要是来自 darkreader 的错误，直接拦截
                const errStr = args.join(' ');
                if (
                errStr.includes('darkreader') ||
                errStr.includes('Dark Reader') ||
                errStr.includes('cross-origin') ||
                errStr.includes('Could not establish connection') ||
                errStr.includes('Receiving end does not exist')
                ) {
                return;
                }
            } catch (e) {}
            originalError.apply(console, args);
            };

            // 重点：强制让 DarkReader 不尝试跨域请求（根源解决）
            if (window.DarkReader) {
            DarkReader.setFetchMethod(async (url) => {
                try {
                return await fetch(url, { mode: 'no-cors' });
                } catch {
                return new Response(new Blob(), { status: 200, statusText: "OK" });
                }
            });
            }
        </script-->
        <script>
            const drOptions = {
                brightness: 100,
                contrast: 95,
                sepia: 10,
                darkSchemeTextColor: '#e0e0e0',  // 粉笔白文字
                darkSchemeBackgroundColor: '#1e1e1e', // 黑板灰背景
                scrollbarStyle: 'native'
            };
            DarkReader.setFetchMethod(window.fetch);

            const savedTheme = localStorage.getItem('theme');
            const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (savedTheme === 'dark' || (!savedTheme && systemDark)) {
                DarkReader.enable(drOptions);
            }

            window.addEventListener('DOMContentLoaded', () => {
                const btn = document.createElement('button');
                btn.innerText = '🌓';
                // 按钮样式：仿照你之前的布局，放在右下角
                btn.style.cssText = `
                    position: fixed; 
                    bottom: 40px; 
                    left: 42px; 
                    z-index: 9999;
                    width: 44px; 
                    height: 44px; 
                    border-radius: 50%; 
                    border: 1px solid #ccc;
                    background: #f7f5ed; 
                    color: #000;
                    font-size: 22px; 
                    cursor: pointer;
                    box-shadow: 0 4px 10px rgba(0,0,0,0.1); 
                    transition: transform 0.2s, background-color 0.3s;
                `;
                // 根据当前状态初始化按钮颜色
                if (DarkReader.isEnabled()) {
                    btn.style.backgroundColor = '#1e1e1e';
                    btn.style.color = '#fff';
                }
                btn.onmouseover = () => btn.style.transform = 'scale(1.1)';
                btn.onmouseout = () => btn.style.transform = 'scale(1)';
                document.body.appendChild(btn);
                // 点击切换逻辑
                btn.addEventListener('click', () => {
                    if (DarkReader.isEnabled()) {
                        DarkReader.disable();
                        localStorage.setItem('theme', 'light');
                        btn.style.backgroundColor = '#f7f5ed';
                        btn.style.color = '#000';
                    } else {
                        DarkReader.enable(drOptions);
                        localStorage.setItem('theme', 'dark');
                        btn.style.backgroundColor = '#1e1e1e';
                        btn.style.color = '#fff';
                    }
                });
            });
        </script>
        <% } %>

        <!-- Pjax 配置 -->
        <% if (theme.enable_pjax) { %>
        <script>
            $(document).pjax('a[href]:not([href^="#"]):not([href^="javascript:"]):not([target="_blank"])', {
                container: '#paper-content',
                fragment: '#paper-content',
                timeout: 8000,
                cacheBust: false,
                type: 'GET',
                dataType: 'html'
            }).on('pjax:start', function() {
                // Pjax 开始加载前
                // window.scrollTo(0, 0);
            }).on('pjax:end', function() { //之前写的pjax:complete，但是return to last（即window.history.back()）后只会触发pjax:end，而不会触发pjax:complete，导致一些reinit动作无法被执行到，因此更换为pjax:end
                // Pjax 加载完成后
                window.scrollTo(0, 0);
                // 重新初始化动态内容
                initDynamicContent();
            });
        </script>
        <% } %>

        <% if (theme.post_calendar) { %>
        <% if (theme.enable_pjax) { %>
            <% if (!locals.loadedLibs.includes('echarts')) { %>
                <script src="<%= cdn_lib_url('echarts') %>"></script>
                <% locals.loadedLibs.push('echarts'); %>
            <% } %>
        <% } else { %>
            <% if (is_home()) { %>
                <% if (!locals.loadedLibs.includes('echarts')) { %>
                    <script src="<%= cdn_lib_url('echarts') %>"></script>
                    <% locals.loadedLibs.push('echarts'); %>
                <% } %>
            <% } %>
        <% } %>
        <% } %>

        <% if (theme.comment.enable && (!theme.no_internet_local_deploy || (theme.no_internet_local_deploy && theme.no_internet_local_deploy_enable_comment))) { %>
          <% if (theme.comment.use === 'waline') { %>
            <% if (theme.enable_pjax) { %>
                <script src="<%= theme.waline_js %>"></script>
            <% } else { %>
                <% if ((is_post() || is_page()) && ( page.hasOwnProperty('comment') ? !!page.comment : (!!theme.comment.waline.serverUrl && !!theme.comment.waline.lang) )) { %>
                    <!-- 正确、稳定、永远不报错的 Waline UMD 版本. 注意(is_post() || is_page())的条件是为了排除is_home() -->
                    <script src="<%= theme.waline_js %>"></script>
                <% } %>
            <% } %>
          <% } %>
        <% } %>

        <% if(theme.index.hitokoto && (!theme.no_internet_local_deploy || (theme.no_internet_local_deploy && theme.no_internet_local_deploy_enable_comment))) { %>
            <% if (theme.enable_pjax) { %>
                <% if (cdnEnabled) { %>
                    <script src="<%= cdn_theme_url('/js/hitokoto.js') %>" ></script>
                <% } else { %>
                    <script src="<%= url_for('/js/hitokoto.js') %>" ></script>
                <% } %>
            <% } %>
        <% } %>
        
        <% if (theme.typed_printer) { %>
            <% if (!locals.loadedLibs.includes('typed-printer')) { %>
                <script src="<%= cdn_lib_url('typed-printer') %>"></script>
                <% locals.loadedLibs.push('typed-printer'); %>
            <% } %>
        <% } %>

        <div class="paper" id="paper-content">
            <% if(theme.tool.leftToc) { %>
                <% if(is_post() && (!('leftToc' in page) || page.leftToc == true)) { %>
                    <div class="left-toc-container">
                        <nav id="toc" class="bs-docs-sidebar"></nav>
                    </div>
                <% } %>
            <% } %>

            <% var tags,tagsInside, categories, categoriesInside; %>

            <% if(path == "index.html") { %>
                <div class="shadow-drop-2-bottom index-main">
                    <%- partial('_partial/header') %>
                    <%- partial('index') %>
                    <% if(theme.index.list) { %>
                        <%- partial('list') %>
                    <% } %>
                    <%- partial('_partial/footer') %>
                </div>
            <% } else if(path == "list/index.html") { %>
                <div class="shadow-drop-2-top paper-main">
                     <%- partial('_partial/post-header') %>
                     <%- partial('list') %>
                     <%- partial('_partial/footer') %>
                </div>
            <% } else if(path == "404.html") { %>
                <div class="shadow-drop-2-top paper-main">
                    <%- partial('_partial/404-template') %>
                    <%- partial('_partial/footer') %>
                </div>
            <% } else if(path == "recent-updates/index.html") { %>
                <div class="shadow-drop-2-top paper-main">
                    <%- partial('_partial/post-header') %>
                    <%- partial('_partial/recent-updates') %>
                    <%- partial('_partial/footer') %>
               </div>
            <% } else { %>
                <div class="shadow-drop-2-bottom paper-main">
                    <%- partial('_partial/post-header') %>

                    <% if(tags = (path == "tags/index.html")) { %>
                            <%- partial('tags') %>
                    <% } %>
                    <% if(categories = (path == "categories/index.html")) { %>
                            <%- partial('categories') %>
                    <% } %>

                    <% if(tagsInside = (path.length > "tags/index.html".length && path.substring(0, 5) == "tags/")) { %>
                            <%- partial('_partial/tags-list') %>
                    <% } %>
                    <% if(categoriesInside = (path.length > "categories/index.html".length && path.substring(0, 11) == "categories/")) { %>
                        <%- partial('_partial/categories-list') %>
                    <% } %>

                    <!--说明是文章post页面-->
                    <% if (!tags && !categories && !tagsInside && !categoriesInside) { %>
                        <%- partial('post') %>

                    <% } %>

                    <%- partial('_partial/footer') %>
                </div>
            <% } %>
            <% if(theme.tool.returnToTop) { %>
                <!-- 回到顶部的按钮-->
                <div class="progress-wrap shadow-drop-2-bottom">
                    <svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
                        <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98"/>
                    </svg>
                </div>
            <% } %>
            <% if(theme.tool.returnToLast) { %>
                <!-- 返回的按钮-->
                <div class="return-to-last-progress-wrap shadow-drop-2-bottom">
                    <svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
                        <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98"/>
                    </svg>
                </div>
            <% } %>
    </body>

<%
