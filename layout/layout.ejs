    <% if (config.mermaid && config.mermaid.enable) { %>
        <% if (theme.no_internet_local_deploy) { %>
            <script src="/js/mermaid.min.js"></script> <!--script src="<%= cdn_theme_url('js/mermaid.min.js') %>"></script-->
